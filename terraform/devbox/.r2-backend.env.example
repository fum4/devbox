# Copy to .r2-backend.env (gitignored, chmod 600) and fill in. Source it before
# any terraform command that touches state (init/plan/apply/import) — the
# devbox-tf wrapper does this for you:
#
#   set -a && . ./.r2-backend.env && set +a
#
# These are the R2 access keys for the `devbox-backup` bucket (Cloudflare →
# R2 → Manage API tokens → scoped to devbox-backup, Object Read & Write).
# Lane-2 credential: laptop-only, gitignored, backed up in Bitwarden.
AWS_ACCESS_KEY_ID="REPLACE_ME"
AWS_SECRET_ACCESS_KEY="REPLACE_ME"
