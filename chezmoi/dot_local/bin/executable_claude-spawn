#!/usr/bin/env bash
# claude-spawn — start a Claude agent session supervised by systemd.
#
#   claude-spawn --name <name> [--cwd <dir>] [--prompt-file <path>] \
#                              [--resume <id>] [--permission-mode <mode>]
#
# The session runs as `claude@<name>.service` (a systemd *user* unit) holding a
# `dtach` PTY, started with `--remote-control <name>` so it shows up in the
# phone Claude app, named. Lifecycle is owned by systemd: it survives SSH drops,
# laptop sleep, and a dead Zellij viewer, and is isolated from every other
# session. Attach an interactive terminal from the laptop with `zj <project>`
# (the dashboard) or `dtach -a $XDG_RUNTIME_DIR/claude-<name>.sock`.
# See ~/code/devbox/docs/sessions.md.
#
#   --cwd              working directory (default: $PWD)
#   --prompt-file      file whose contents become --append-system-prompt (how
#                      /new-work-session primes its clarify→worktree→code flow);
#                      copied to a stable per-session file so it survives restarts
#   --resume           resume an EXISTING conversation by id (else a fresh UUID
#                      is generated and pinned for the session's life)
#   --permission-mode  default / acceptEdits / bypassPermissions / plan
#                      (default: bypassPermissions — phone-driven flow asks about
#                      *what* to build, not whether each tool call is allowed)

set -euo pipefail

CONF_DIR="$HOME/.config/claude-sessions"

name=""; cwd="$PWD"; prompt_file=""; resume=""; permission_mode="bypassPermissions"
while [[ $# -gt 0 ]]; do
    case "$1" in
        --name)            name="${2:-}"; shift 2 ;;
        --cwd)             cwd="${2:-}"; shift 2 ;;
        --prompt-file)     prompt_file="${2:-}"; shift 2 ;;
        --resume)          resume="${2:-}"; shift 2 ;;
        --permission-mode) permission_mode="${2:-}"; shift 2 ;;
        *) echo "claude-spawn: unknown argument '$1'" >&2; exit 2 ;;
    esac
done

[[ -n "$name" ]] || { echo "claude-spawn: --name is required" >&2; exit 2; }
# The name becomes a systemd instance, a socket path, and a filename — keep it
# to a safe charset (the session-naming convention is kebab-case anyway).
[[ "$name" =~ ^[A-Za-z0-9._-]+$ ]] || {
    echo "claude-spawn: --name '$name' must be [A-Za-z0-9._-] (kebab-case)" >&2; exit 2; }

case "$permission_mode" in
    default|acceptEdits|bypassPermissions|plan) ;;
    *) echo "claude-spawn: invalid --permission-mode '$permission_mode' (expected default|acceptEdits|bypassPermissions|plan)" >&2; exit 2 ;;
esac

[[ -d "$cwd" ]] || { echo "claude-spawn: cwd '$cwd' does not exist" >&2; exit 1; }
[[ -z "$prompt_file" || -f "$prompt_file" ]] || { echo "claude-spawn: --prompt-file '$prompt_file' not found" >&2; exit 1; }
command -v dtach >/dev/null || { echo "claude-spawn: dtach not on PATH (run devbox-reprov --tags dtach)" >&2; exit 1; }

# Refuse to clobber a session that's already running under this name.
if systemctl --user --quiet is-active "claude@${name}.service" 2>/dev/null; then
    echo "claude-spawn: session '$name' is already active (systemctl --user status claude@${name})" >&2
    exit 1
fi

cwd="$(cd "$cwd" && pwd -P)"   # normalise for a stable transcript path
mkdir -p "$CONF_DIR"

# Pin the conversation id: reuse an explicit --resume id, else mint a fresh UUID.
session_id="${resume:-$(cat /proc/sys/kernel/random/uuid)}"

env_file="$CONF_DIR/${name}.env"
{
    echo "SESSION_ID=$session_id"
    echo "CWD=$cwd"
    echo "PERM_MODE=$permission_mode"
} > "$env_file"

# Persist the append-prompt to a stable per-session file so it survives restarts
# (the launcher re-reads it on every start, including crash-restarts).
if [[ -n "$prompt_file" ]]; then
    prompt_dest="$CONF_DIR/${name}.prompt"
    cp -f "$prompt_file" "$prompt_dest"
    echo "APPEND_PROMPT_FILE=$prompt_dest" >> "$env_file"
fi

# daemon-reload guarantees the units are current even if a chezmoi apply ran
# without a user bus (e.g. under Ansible). Idempotent + instant.
systemctl --user daemon-reload
systemctl --user start "claude@${name}.service"

echo "Spawned Claude session '$name' (claude@${name}.service) in $cwd."
echo "  conversation: $session_id"
echo "  attach (laptop): zj <project>   ·   or: dtach -a \$XDG_RUNTIME_DIR/claude-${name}.sock  (detach: Ctrl-\\)"
echo "  logs: journalctl --user -u claude@${name} -f"
echo "Refresh the phone Claude app — it'll appear in the session list."
