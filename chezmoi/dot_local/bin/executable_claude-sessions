#!/usr/bin/env bash
# claude-sessions — inventory of Claude agent sessions + git worktrees on the
# devbox. Facts only, no LLM. The /sessions and /prune skills layer
# interpretation (transcript gist, prune candidacy) on top of this.
#
#   claude-sessions          human-readable report (default)
#
# Enumeration is systemd-driven: each agent session is a `claude@<name>.service`
# user unit with a matching ~/.config/claude-sessions/<name>.env (SESSION_ID,
# CWD, …). We list every known session (active, stopped, or failed), plus any
# *unmanaged* stray `claude` processes not under the claude.slice (so nothing
# hides). See ~/code/devbox/docs/sessions.md.
#
# A session's transcript (for the /sessions gist) lives at:
#   ~/.claude/projects/<cwd-with-slashes-as-dashes>/<SESSION_ID>.jsonl

set -u

CONF_DIR="$HOME/.config/claude-sessions"
PROJ_DIR="$HOME/.claude/projects"
CODE_DIR="$HOME/code"
NOW_S=$(date +%s)

if [[ -t 1 ]]; then
    BOLD=$'\e[1m'; DIM=$'\e[2m'; YEL=$'\e[33m'; GRN=$'\e[32m'; RED=$'\e[31m'; RESET=$'\e[0m'
else
    BOLD=""; DIM=""; YEL=""; GRN=""; RED=""; RESET=""
fi

tilde() { printf '%s' "${1/#$HOME/\~}"; }

rel_time() {  # epoch-seconds → "Nm ago"
    local s="$1" d
    if [[ -z "$s" || "$s" == "0" ]]; then echo "?"; return; fi
    d=$(( NOW_S - s ))
    if   (( d < 60 ));    then echo "${d}s ago"
    elif (( d < 3600 ));  then echo "$(( d / 60 ))m ago"
    elif (( d < 86400 )); then echo "$(( d / 3600 ))h ago"
    else echo "$(( d / 86400 ))d ago"; fi
}

uctl() { systemctl --user "$@" 2>/dev/null; }

# Emit one TSV line per known session: name \t state \t cwd \t sessionId \t lastActive(s)
known_sessions() {
    local f name sid cwd state transcript last
    [[ -d "$CONF_DIR" ]] || return 0
    for f in "$CONF_DIR"/*.env; do
        [[ -e "$f" ]] || continue
        name="$(basename "$f" .env)"
        sid=""; cwd=""
        # shellcheck disable=SC1090
        while IFS='=' read -r k v; do
            case "$k" in SESSION_ID) sid="$v" ;; CWD) cwd="$v" ;; esac
        done < "$f"
        state="$(uctl is-active "claude@${name}.service")"; state="${state:-unknown}"
        last=0
        transcript="$PROJ_DIR/${cwd//\//-}/$sid.jsonl"
        [[ -f "$transcript" ]] && last=$(stat -c %Y "$transcript" 2>/dev/null || echo 0)
        printf '%s\t%s\t%s\t%s\t%s\n' "$name" "$state" "$cwd" "$sid" "$last"
    done
}

# Stray `claude` processes NOT under the claude.slice (run by hand, pre-migration
# zellij tabs, this very process, …). Emits: pid \t name \t cwd
unmanaged_sessions() {
    local pid cg cmd name cwd
    while read -r pid; do
        [[ -n "$pid" && -d "/proc/$pid" ]] || continue
        cg=$(tr '\0' ' ' < "/proc/$pid/cgroup" 2>/dev/null)
        [[ "$cg" == *"claude.slice/claude@"* ]] && continue   # managed — skip
        cmd=$(tr '\0' '\n' < "/proc/$pid/cmdline" 2>/dev/null)
        name=$(printf '%s\n' "$cmd" | grep -A1 -x -- '--remote-control' | tail -1)
        [[ -n "$name" && "$name" != "--remote-control" ]] || name="(no remote-control)"
        cwd=$(readlink "/proc/$pid/cwd" 2>/dev/null)
        printf '%s\t%s\t%s\n' "$pid" "$name" "$cwd"
    done < <(pgrep -x claude)
}

branch_of() {
    git -C "$1" rev-parse --git-dir >/dev/null 2>&1 || return
    git -C "$1" symbolic-ref --quiet --short HEAD 2>/dev/null || echo "detached"
}

SESSIONS="$(known_sessions)"
UNMANAGED="$(unmanaged_sessions)"

sessions_in() {  # names of sessions (managed + unmanaged) whose cwd == $1
    printf '%s\n' "$SESSIONS"  | awk -F'\t' -v p="$1" '$3 == p { printf "%s ", $1 }'
    printf '%s\n' "$UNMANAGED" | awk -F'\t' -v p="$1" '$3 == p { printf "%s ", $2 }'
}

echo "${BOLD}CLAUDE SESSIONS${RESET} ${DIM}(systemd-managed)${RESET}"
if [[ -z "$SESSIONS" ]]; then
    echo "  (none)"
else
    while IFS=$'\t' read -r name state cwd sid last; do
        [[ -z "$name" ]] && continue
        case "$state" in
            active)   dot="${GRN}●${RESET}" ;;
            failed)   dot="${RED}●${RESET}" ;;
            *)        dot="${DIM}○${RESET}" ;;
        esac
        branch="$(branch_of "$cwd")"
        printf '\n  %s %s%s%s  %s%s · %s%s\n' \
            "$dot" "$BOLD" "$name" "$RESET" "$DIM" "$state" "$(rel_time "$last")" "$RESET"
        printf '      cwd:    %s%s\n' "$(tilde "$cwd")" "${branch:+  [$branch]}"
        printf '      conv:   %s%s%s\n' "$DIM" "$sid" "$RESET"
        if [[ "$state" == active ]]; then
            # shellcheck disable=SC2016  # $XDG_RUNTIME_DIR is meant to print literally (the user copies the command)
            printf '      attach: %sdtach -a $XDG_RUNTIME_DIR/claude-%s.sock%s\n' "$DIM" "$name" "$RESET"
        else
            printf '      resume: %sclaude-restore %s%s   (or systemctl --user start claude@%s)\n' "$DIM" "$name" "$RESET" "$name"
        fi
    done <<< "$SESSIONS"
fi

if [[ -n "$UNMANAGED" ]]; then
    echo
    echo "${YEL}UNMANAGED claude processes${RESET} ${DIM}(not under systemd — consider re-spawning via claude-spawn)${RESET}"
    while IFS=$'\t' read -r pid name cwd; do
        [[ -z "$pid" ]] && continue
        printf '  %spid %-7s%s %s%s%s  %s%s%s\n' \
            "$DIM" "$pid" "$RESET" "$BOLD" "$name" "$RESET" "$DIM" "$(tilde "$cwd")" "$RESET"
    done <<< "$UNMANAGED"
fi

echo
echo "${BOLD}WORKTREES${RESET}"
{
    for repo in "$CODE_DIR"/*/; do
        repo="${repo%/}"
        [[ -e "$repo/.git" ]] || continue
        git -C "$repo" worktree list --porcelain 2>/dev/null | awk '
            /^worktree /{wt=$2}
            /^branch /{sub("refs/heads/","",$2); br=$2}
            /^detached/{br="detached"}
            /^$/{if(wt){print wt"\t"br; wt="";br=""}}
            END{if(wt)print wt"\t"br}'
    done | sort -u
} | while IFS=$'\t' read -r wt br; do
    [[ -z "$wt" ]] && continue
    here=$(sessions_in "$wt")
    dirty=$(git -C "$wt" status --porcelain 2>/dev/null | wc -l)
    if [[ -n "$here" ]]; then
        note="session: ${here% }"
    else
        note="${DIM}no live session${RESET}"
    fi
    (( dirty > 0 )) && note="$note · ${YEL}⚠ $dirty uncommitted${RESET}"
    printf '  %-30s %s%-12s%s %s\n' "$(tilde "$wt")" "$DIM" "[$br]" "$RESET" "$note"
done

echo
echo "${DIM}tip: /sessions adds a one-line gist per session; /prune flags stale ones.${RESET}"
