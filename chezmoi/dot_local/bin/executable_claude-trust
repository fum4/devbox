#!/usr/bin/env bash
# claude-trust — mark workspace(s) as trusted in ~/.claude.json so Claude Code
# sessions started there skip the workspace-trust dialog.
#
#   claude-trust <path>...   trust specific paths
#   claude-trust --all       trust every git repo + worktree under ~/code/
#                            (skips any whose trust is already inherited from
#                             an ancestor)
#
# Why this exists: Claude Code blocks startup on a workspace-trust dialog the
# first time it opens an unknown path. For a spawned/headless session nobody
# attaches to, that means startup never finishes and Remote Control never
# registers — so it never appears in the phone app.
#
# How trust actually resolves (verified against Claude Code 2.1.x binary):
# the trust flag (`.projects["<abs-path>"].hasTrustDialogAccepted`) IS
# inherited from any ancestor dir whose flag is set to `true` — Claude walks
# the path tree upward until it finds one. So trusting `~/code` once with
# `hasTrustDialogAccepted: true` covers every repo and worktree underneath.
# This script honors that: if any ancestor of <path> has the flag set to
# true, it does nothing for that <path>.
#
# IMPORTANT gotcha: a `.projects["<path>"]` entry can exist with
# `hasTrustDialogAccepted: false` (Claude adds skeleton entries for paths it's
# touched, with the flag default-false). Such an entry does NOT count as
# trust — only `true` does. Checking `.projects | keys` will mislead you.
#
# This script seeds the flag idempotently. Safe to call from `claude-spawn`,
# `wt new`, or by hand. With --all, traverses ~/code/ once.

set -euo pipefail

CLAUDE_JSON="$HOME/.claude.json"
CODE_DIR="$HOME/code"

# Echoes "true" iff <path> or any of its ancestors has hasTrustDialogAccepted
# set in $CLAUDE_JSON. Mirrors the binary's parent-walk semantics.
is_trusted_via_ancestor() {
    local p="$1" cur="$1"
    while :; do
        if [[ "$(jq -r --arg c "$cur" '.projects[$c].hasTrustDialogAccepted // false' "$CLAUDE_JSON" 2>/dev/null)" == "true" ]]; then
            echo "true"; return
        fi
        local parent
        parent=$(dirname "$cur")
        [[ "$parent" == "$cur" ]] && break
        cur="$parent"
    done
    echo "false"
}

paths=()
if [[ "${1:-}" == "--all" ]]; then
    shopt -s nullglob
    for repo in "$CODE_DIR"/*/; do
        repo="${repo%/}"
        [[ -e "$repo/.git" ]] || continue
        while read -r wt; do [[ -n "$wt" ]] && paths+=("$wt"); done \
            < <(git -C "$repo" worktree list --porcelain 2>/dev/null | awk '/^worktree /{print $2}')
    done
else
    [[ $# -gt 0 ]] || { echo "usage: claude-trust <path>... | --all" >&2; exit 2; }
    for p in "$@"; do paths+=("$(readlink -f "$p" 2>/dev/null || echo "$p")"); done
fi

[[ -f "$CLAUDE_JSON" ]] || echo '{}' > "$CLAUDE_JSON"

# Dedupe.
mapfile -t paths < <(printf '%s\n' "${paths[@]}" | awk 'NF' | sort -u)

trusted=0
skipped=0
for p in "${paths[@]}"; do
    if [[ "$(is_trusted_via_ancestor "$p")" == "true" ]]; then
        skipped=$((skipped + 1))
        continue
    fi
    tmp=$(mktemp)
    jq --arg p "$p" '.projects[$p] = ((.projects[$p] // {}) + {hasTrustDialogAccepted: true})' \
        "$CLAUDE_JSON" > "$tmp" && mv "$tmp" "$CLAUDE_JSON"
    echo "trusted: $p"
    trusted=$((trusted + 1))
done

if (( trusted == 0 )); then
    echo "claude-trust: nothing to do (${#paths[@]} path(s) already covered by an ancestor trust entry)"
fi
