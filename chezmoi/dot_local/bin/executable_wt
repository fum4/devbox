#!/bin/bash
# wt — worktree + PR + merge helper for the devbox.
# Run `wt help` for the command listing.
#
# Design: agents and humans should use `wt new`, `wt pr`, `wt merge` rather
# than raw `git worktree` / `gh pr` commands. The wrappers wire in sync
# (fetch + branch-from-origin), rebase, force-push-with-lease, and cleanup
# automatically so they're not forgotten.

set -euo pipefail

die() { echo "wt: $*" >&2; exit 1; }

is_in_repo() {
    git rev-parse --git-dir >/dev/null 2>&1
}

repo_default_branch() {
    git symbolic-ref --quiet refs/remotes/origin/HEAD 2>/dev/null \
        | sed 's|refs/remotes/origin/||' \
        || echo "main"
}

repo_main_worktree() {
    git worktree list --porcelain | awk '/^worktree /{print $2; exit}'
}

cmd_help() {
    cat <<'EOF'
wt — worktree + PR + merge helper for the devbox.

USAGE
  wt new <task>           Branch a worktree from origin/<default> into ../<repo>-<task>
  wt pr [gh-args…]        Rebase + force-push-with-lease + gh pr create
  wt merge [strategy]     Merge PR (default --squash) + delete branches + clean up worktree.
                          Also works from a main checkout sitting on the feature branch
                          (merges, then returns the checkout to <default>).
  wt rm <task> [--force]  Remove a worktree. Refuses unless PR is MERGED (or --force).
  wt wip [path]           WIP report for a checkout: branch, uncommitted, stashes,
                          unpushed, PR state, gitignored env files.
  wt env [task]           Mirror gitignored .env* files from the main checkout into a
                          worktree (never overwrites). Runs automatically after wt new.
  wt help                 Show this help.

  For listing worktrees use `git worktree list`. To spawn a worktree-backed
  session use the /new-work-session skill; to clean up stale worktrees use the
  session-aware /prune skill — both build on the commands above.

CONVENTIONS
  task    short kebab-case slug (e.g. auth-fix, receipt-ocr)
  branch  defaults to the task name
  path    ../<repo>-<task> (sibling to the main checkout)

When to use a worktree: see AGENTS.md → "When to use a worktree".
EOF
}

cmd_new() {
    local task="${1:-}"
    [[ -z "$task" ]] && die "usage: wt new <task>"
    is_in_repo || die "not inside a git repo"

    local repo_root default wt_path
    repo_root=$(git rev-parse --show-toplevel)
    default=$(repo_default_branch)

    git fetch --quiet origin || die "git fetch failed"

    wt_path="${repo_root}-${task}"
    [[ -e "$wt_path" ]] && die "$wt_path already exists"

    git worktree add "$wt_path" -b "$task" "origin/$default"
    mirror_env_files "$repo_root" "$wt_path"
    echo
    echo "Worktree: $wt_path"
    echo "Branch:   $task (from origin/$default)"
    echo "Next:     cd $wt_path"
}

# Mirror gitignored env files (.env, .env.local, apps/*/.env*, …) from one
# checkout into another at the same relative paths. Never overwrites. Flags
# host-pointing values for human judgment (can't be rewritten safely).
# --directory collapses fully-ignored dirs (node_modules) — fast, and avoids
# matching junk inside them; the trade-off is that an env file living INSIDE an
# ignored dir isn't found (document those per-repo, per AGENTS.md).
mirror_env_files() {
    local src="$1" dst="$2" f copied=0 hosty=()
    while IFS= read -r f; do
        [[ -z "$f" ]] && continue
        [[ -e "$dst/$f" ]] && continue          # never overwrite
        mkdir -p "$dst/$(dirname "$f")"
        cp "$src/$f" "$dst/$f"
        copied=$((copied + 1))
        echo "  env: mirrored $f"
        if grep -qE 'localhost|127\.0\.0\.1|[0-9]{1,3}(\.[0-9]{1,3}){3}' "$dst/$f"; then
            hosty+=("$f")
        fi
    done < <(git -C "$src" ls-files --others --ignored --exclude-standard --directory \
             | grep -E '(^|/)\.env[^/]*$' || true)
    if [[ "$copied" -gt 0 && "${#hosty[@]}" -gt 0 ]]; then
        echo "  env: check host-pointing values (localhost/IPs) in: ${hosty[*]}"
        echo "       (laptop-authored envs may need the devbox Tailscale FQDN)"
    fi
}

cmd_env() {
    is_in_repo || die "not inside a git repo"
    local main current src dst
    main=$(repo_main_worktree)
    current=$(git rev-parse --show-toplevel)

    if [[ -n "${1:-}" ]]; then
        dst="${main}-${1}"
        [[ -d "$dst" ]] || dst=$(git worktree list --porcelain \
                                 | awk -v t="$1" '/^worktree / && index($2, t){print $2; exit}')
        [[ -n "$dst" && -d "$dst" ]] || die "no worktree matching '$1'"
    else
        [[ "$current" == "$main" ]] && die "run 'wt env' from inside a worktree, or pass <task>"
        dst="$current"
    fi
    src="$main"
    [[ "$src" == "$dst" ]] && die "source and destination are the same checkout"

    mirror_env_files "$src" "$dst"
    echo "env files mirrored: $src → $dst (existing files untouched)"
}

cmd_wip() {
    local path="${1:-.}"
    git -C "$path" rev-parse --git-dir >/dev/null 2>&1 || die "not a git checkout: $path"

    local root branch default gd gcd kind upstream pr envs
    root=$(git -C "$path" rev-parse --show-toplevel)
    branch=$(git -C "$root" symbolic-ref --short HEAD 2>/dev/null || echo "DETACHED")
    gd=$(git -C "$root" rev-parse --git-dir)
    gcd=$(git -C "$root" rev-parse --git-common-dir)
    if [[ "$gd" == "$gcd" ]]; then kind="main-checkout"; else kind="linked-worktree"; fi
    default=$(git -C "$root" symbolic-ref --quiet refs/remotes/origin/HEAD 2>/dev/null \
        | sed 's|refs/remotes/origin/||' || echo "main")

    echo "checkout: $root ($kind)"
    echo "branch: $branch (default: $default)"
    echo "uncommitted: $(git -C "$root" status --porcelain | wc -l)"
    echo "stashes: $(git -C "$root" stash list | wc -l)"
    if upstream=$(git -C "$root" rev-parse --abbrev-ref '@{u}' 2>/dev/null); then
        echo "unpushed: $(git -C "$root" rev-list --count '@{u}..HEAD') (ahead of $upstream)"
    else
        echo "unpushed: no upstream (branch never pushed)"
    fi
    if [[ "$branch" == "$default" || "$branch" == "DETACHED" ]]; then
        echo "pr: n/a"
    else
        pr=$(cd "$root" && gh pr list --head "$branch" --state all \
             --json number,state --jq '.[0] | "#\(.number) \(.state)"' 2>/dev/null || true)
        echo "pr: ${pr:-none}"
    fi
    envs=$(git -C "$root" ls-files --others --ignored --exclude-standard --directory \
           | grep -E '(^|/)\.env[^/]*$' | paste -sd' ' - || true)
    echo "env-files: ${envs:-none}"
}

cmd_pr() {
    is_in_repo || die "not inside a git repo"
    local main current default branch
    main=$(repo_main_worktree)
    current=$(git rev-parse --show-toplevel)
    [[ "$current" == "$main" ]] && die "run 'wt pr' from inside a worktree, not main"

    default=$(repo_default_branch)
    branch=$(git symbolic-ref --short HEAD)

    git fetch --quiet origin

    echo "Rebasing $branch on origin/$default..."
    if ! git rebase "origin/$default"; then
        die "rebase conflicts — resolve, run 'git rebase --continue', then re-run 'wt pr'"
    fi

    git push --force-with-lease -u origin HEAD

    gh pr create "$@"
}

cmd_merge() {
    is_in_repo || die "not inside a git repo"
    local strategy="${1:---squash}"

    local main current default branch in_main=0
    main=$(repo_main_worktree)
    current=$(git rev-parse --show-toplevel)
    default=$(repo_default_branch)
    branch=$(git symbolic-ref --short HEAD)

    if [[ "$current" == "$main" ]]; then
        # Feature branch checked out directly in the main checkout (no worktree).
        # Supported: merge the PR, then return the checkout to <default>.
        [[ "$branch" == "$default" ]] \
            && die "main checkout is on $default — nothing to merge (run from a worktree, or check out the feature branch first)"
        in_main=1
    fi

    local pr state
    pr=$(gh pr view --json number --jq .number 2>/dev/null) \
        || die "no PR for $branch (open one with 'wt pr')"
    state=$(gh pr view "$pr" --json state --jq .state)

    case "$state" in
        MERGED) echo "PR #$pr already merged. Cleaning up." ;;
        CLOSED) die "PR #$pr is closed (not merged). Use 'wt rm <task> --force' to discard." ;;
        # Deliberately NOT gh's --delete-branch: run from a worktree it tries to
        # check out <default> locally, which fatals ('main is already used by
        # worktree …') and aborts before any cleanup. The remote branch is
        # deleted explicitly below instead.
        OPEN)   gh pr merge "$pr" "$strategy" ;;
        *)      die "unexpected PR state: $state" ;;
    esac

    cd "$main"
    git fetch --quiet origin
    if [[ "$in_main" -eq 1 ]]; then
        git checkout --quiet "$default"
    fi
    if [[ "$(git symbolic-ref --short HEAD 2>/dev/null)" == "$default" ]]; then
        git pull --ff-only --quiet origin "$default"
    fi
    if [[ "$in_main" -eq 0 ]]; then
        git worktree remove "$current"
    fi
    git branch -D "$branch" 2>/dev/null || true
    git push --quiet origin --delete "$branch" 2>/dev/null || true  # may already be auto-deleted
    if [[ "$in_main" -eq 1 ]]; then
        echo "Done: PR #$pr merged, main checkout back on $default, branch $branch deleted."
    else
        echo "Done: PR #$pr merged, worktree removed, branch $branch deleted."
    fi
}

cmd_rm() {
    local task="${1:-}"
    local force=0
    [[ "${2:-}" == "--force" ]] && force=1
    [[ -z "$task" ]] && die "usage: wt rm <task> [--force]"
    is_in_repo || die "not inside a git repo"

    local repo_root wt_path branch
    repo_root=$(git rev-parse --show-toplevel)
    wt_path="${repo_root}-${task}"
    if [[ ! -d "$wt_path" ]]; then
        wt_path=$(git worktree list --porcelain \
                  | awk -v t="$task" '/^worktree / && index($2, t){print $2; exit}')
    fi
    [[ -z "$wt_path" || ! -d "$wt_path" ]] && die "no worktree matching '$task'"

    branch=$(git -C "$wt_path" symbolic-ref --short HEAD 2>/dev/null || echo "")

    if [[ "$force" -eq 0 && -n "$branch" ]]; then
        local pr_state
        pr_state=$(gh pr list --head "$branch" --state all --json state --jq '.[0].state' 2>/dev/null || echo "")
        if [[ "$pr_state" != "MERGED" ]]; then
            die "PR for $branch is not MERGED (state=${pr_state:-NONE}). Use --force to discard."
        fi
    fi

    if [[ "$force" -eq 1 ]]; then
        git worktree remove --force "$wt_path"
    else
        git worktree remove "$wt_path"
    fi
    if [[ -n "$branch" ]]; then
        git branch -D "$branch" 2>/dev/null || true
    fi
    echo "Removed worktree: $wt_path"
}

# ----- dispatch -----

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
    new)            cmd_new "$@" ;;
    pr)             cmd_pr "$@" ;;
    merge)          cmd_merge "$@" ;;
    rm)             cmd_rm "$@" ;;
    wip)            cmd_wip "$@" ;;
    env)            cmd_env "$@" ;;
    help|--help|-h) cmd_help ;;
    *)              die "unknown command: $cmd (try 'wt help')" ;;
esac
