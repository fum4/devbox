#!/bin/bash
# wt — worktree + PR + merge helper for the devbox.
# Run `wt help` for the command listing.
#
# Design: agents and humans should use `wt new`, `wt pr`, `wt merge` rather
# than raw `git worktree` / `gh pr` commands. The wrappers wire in sync
# (fetch + branch-from-origin), rebase, force-push-with-lease, and cleanup
# automatically so they're not forgotten.

set -euo pipefail

die() { echo "wt: $*" >&2; exit 1; }

is_in_repo() {
    git rev-parse --git-dir >/dev/null 2>&1
}

repo_default_branch() {
    git symbolic-ref --quiet refs/remotes/origin/HEAD 2>/dev/null \
        | sed 's|refs/remotes/origin/||' \
        || echo "main"
}

repo_main_worktree() {
    git worktree list --porcelain | awk '/^worktree /{print $2; exit}'
}

cmd_help() {
    cat <<'EOF'
wt — worktree + PR + merge helper for the devbox.

USAGE
  wt new <task>           Branch a worktree from origin/<default> into ../<repo>-<task>
  wt pr [gh-args…]        Rebase + force-push-with-lease + gh pr create
  wt merge [strategy]     Merge PR (default --squash, --delete-branch) + clean up worktree
  wt rm <task> [--force]  Remove a worktree. Refuses unless PR is MERGED (or --force).
  wt list                 List worktrees in the current repo.
  wt prune                Sweep merged-PR worktrees across ~/code/* (cron-friendly).
  wt help                 Show this help.

CONVENTIONS
  task    short kebab-case slug (e.g. auth-fix, receipt-ocr)
  branch  defaults to the task name
  path    ../<repo>-<task> (sibling to the main checkout)

See ~/.agents/skills/parallel-work/SKILL.md for when to use which command.
EOF
}

cmd_new() {
    local task="${1:-}"
    [[ -z "$task" ]] && die "usage: wt new <task>"
    is_in_repo || die "not inside a git repo"

    local repo_root default wt_path
    repo_root=$(git rev-parse --show-toplevel)
    default=$(repo_default_branch)

    git fetch --quiet origin || die "git fetch failed"

    wt_path="${repo_root}-${task}"
    [[ -e "$wt_path" ]] && die "$wt_path already exists"

    git worktree add "$wt_path" -b "$task" "origin/$default"
    echo
    echo "Worktree: $wt_path"
    echo "Branch:   $task (from origin/$default)"
    echo "Next:     cd $wt_path"
}

cmd_pr() {
    is_in_repo || die "not inside a git repo"
    local main current default branch
    main=$(repo_main_worktree)
    current=$(git rev-parse --show-toplevel)
    [[ "$current" == "$main" ]] && die "run 'wt pr' from inside a worktree, not main"

    default=$(repo_default_branch)
    branch=$(git symbolic-ref --short HEAD)

    git fetch --quiet origin

    echo "Rebasing $branch on origin/$default..."
    if ! git rebase "origin/$default"; then
        die "rebase conflicts — resolve, run 'git rebase --continue', then re-run 'wt pr'"
    fi

    git push --force-with-lease -u origin HEAD

    gh pr create "$@"
}

cmd_merge() {
    is_in_repo || die "not inside a git repo"
    local strategy="${1:---squash}"

    local main current default branch
    main=$(repo_main_worktree)
    current=$(git rev-parse --show-toplevel)
    [[ "$current" == "$main" ]] && die "run 'wt merge' from inside a worktree, not main"

    branch=$(git symbolic-ref --short HEAD)

    local pr state
    pr=$(gh pr view --json number --jq .number 2>/dev/null) \
        || die "no PR for $branch (open one with 'wt pr')"
    state=$(gh pr view "$pr" --json state --jq .state)

    case "$state" in
        MERGED) echo "PR #$pr already merged. Cleaning up." ;;
        CLOSED) die "PR #$pr is closed (not merged). Use 'wt rm <task> --force' to discard." ;;
        OPEN)   gh pr merge "$pr" "$strategy" --delete-branch ;;
        *)      die "unexpected PR state: $state" ;;
    esac

    cd "$main"
    default=$(repo_default_branch)
    git fetch --quiet origin
    if [[ "$(git symbolic-ref --short HEAD 2>/dev/null)" == "$default" ]]; then
        git pull --ff-only --quiet origin "$default"
    fi
    git worktree remove "$current"
    git branch -D "$branch" 2>/dev/null || true
    echo "Done: PR #$pr merged, worktree removed, branch $branch deleted."
}

cmd_rm() {
    local task="${1:-}"
    local force=0
    [[ "${2:-}" == "--force" ]] && force=1
    [[ -z "$task" ]] && die "usage: wt rm <task> [--force]"
    is_in_repo || die "not inside a git repo"

    local repo_root wt_path branch
    repo_root=$(git rev-parse --show-toplevel)
    wt_path="${repo_root}-${task}"
    if [[ ! -d "$wt_path" ]]; then
        wt_path=$(git worktree list --porcelain \
                  | awk -v t="$task" '/^worktree / && index($2, t){print $2; exit}')
    fi
    [[ -z "$wt_path" || ! -d "$wt_path" ]] && die "no worktree matching '$task'"

    branch=$(git -C "$wt_path" symbolic-ref --short HEAD 2>/dev/null || echo "")

    if [[ "$force" -eq 0 && -n "$branch" ]]; then
        local pr_state
        pr_state=$(gh pr list --head "$branch" --state all --json state --jq '.[0].state' 2>/dev/null || echo "")
        if [[ "$pr_state" != "MERGED" ]]; then
            die "PR for $branch is not MERGED (state=${pr_state:-NONE}). Use --force to discard."
        fi
    fi

    if [[ "$force" -eq 1 ]]; then
        git worktree remove --force "$wt_path"
    else
        git worktree remove "$wt_path"
    fi
    [[ -n "$branch" ]] && git branch -D "$branch" 2>/dev/null || true
    echo "Removed worktree: $wt_path"
}

cmd_list() {
    is_in_repo || die "not inside a git repo"
    git worktree list
}

cmd_prune() {
    # Idempotent: sweep all repos in ~/code/, remove worktrees whose PR is MERGED.
    # Designed to run from cron.
    shopt -s nullglob
    local repo main_in_repo
    for repo in "$HOME"/code/*/; do
        repo="${repo%/}"
        [[ -d "$repo/.git" ]] || continue

        # Operate only when we're on the canonical main checkout for this repo
        main_in_repo=$(git -C "$repo" worktree list --porcelain | awk '/^worktree /{print $2; exit}')
        [[ "$main_in_repo" != "$repo" ]] && continue

        git -C "$repo" worktree list --porcelain \
            | awk '/^worktree /{wt=$2} /^branch refs\/heads\//{print wt, substr($2, 12)}' \
            | while read -r wt_path branch; do
                  [[ "$wt_path" == "$main_in_repo" ]] && continue
                  local merged_count
                  merged_count=$(gh -R "$(git -C "$repo" config --get remote.origin.url \
                                          | sed -E 's|.*[:/]([^/]+/[^/]+)(\.git)?$|\1|; s|\.git$||')" \
                                 pr list --head "$branch" --state merged --json number --jq 'length' 2>/dev/null || echo 0)
                  if [[ "${merged_count:-0}" -gt 0 ]]; then
                      echo "[wt prune] $(basename "$repo"): removing $wt_path (branch $branch merged)"
                      git -C "$repo" worktree remove "$wt_path" 2>/dev/null \
                          && git -C "$repo" branch -D "$branch" 2>/dev/null || true
                  fi
              done
    done
}

# ----- dispatch -----

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
    new)            cmd_new "$@" ;;
    pr)             cmd_pr "$@" ;;
    merge)          cmd_merge "$@" ;;
    rm)             cmd_rm "$@" ;;
    list)           cmd_list ;;
    prune)          cmd_prune ;;
    help|--help|-h) cmd_help ;;
    *)              die "unknown command: $cmd (try 'wt help')" ;;
esac
