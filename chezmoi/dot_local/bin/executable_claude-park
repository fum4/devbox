#!/usr/bin/env bash
# claude-park <session-name> — "park, not kill" an agent session.
#
# Stops the session's systemd unit (claude@<name>.service). The env file and the
# pinned SESSION_ID persist, so the conversation is fully recoverable later with
# `claude-restore <name>`. Records the park to ~/.claude/parked-sessions.log
# first. Parking only stops the process; it does NOT forget the session (that's a
# deliberate `rm ~/.config/claude-sessions/<name>.env`).
#
# Used by the /prune skill (under per-item user confirmation) and fine to call
# directly. No Zellij required — lifecycle lives in systemd. See docs/sessions.md.

set -euo pipefail

PARK_LOG="$HOME/.claude/parked-sessions.log"
CONF_DIR="$HOME/.config/claude-sessions"
name="${1:-}"
[[ -n "$name" ]] || { echo "usage: claude-park <session-name>" >&2; exit 2; }

env_file="$CONF_DIR/$name.env"
[[ -f "$env_file" ]] || { echo "claude-park: no known session '$name' ($env_file missing)" >&2; exit 1; }

sid="$(sed -n 's/^SESSION_ID=//p' "$env_file")"
cwd="$(sed -n 's/^CWD=//p' "$env_file")"

# Record BEFORE stopping — this is the whole point.
printf '%s\tname=%s\tcwd=%s\tconv=%s\trestore=claude-restore %s\n' \
    "$(date -Is)" "$name" "$cwd" "${sid:-?}" "$name" >> "$PARK_LOG"

systemctl --user stop "claude@${name}.service" 2>/dev/null || true
systemctl --user reset-failed "claude@${name}.service" 2>/dev/null || true

echo "Parked '$name' → $PARK_LOG"
echo "  stopped claude@${name}; conversation ${sid:-?} preserved"
echo "  restore: claude-restore $name"
